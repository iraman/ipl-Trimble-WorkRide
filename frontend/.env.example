# Trimble ID Configuration
# Get these values from Trimble Developer Console: https://developer.trimble.com/

# Your Trimble Application Client ID
VITE_TRIMBLE_CLIENT_ID=YOUR_CLIENT_ID

# Optional: Trimble Identity configuration endpoint
# Default is: https://id.trimble.com/.well-known/openid-configuration
VITE_TRIMBLE_CONFIG_ENDPOINT=https://id.trimble.com/.well-known/openid-configuration

# Backend API Configuration
VITE_API_URL=http://localhost:3001
