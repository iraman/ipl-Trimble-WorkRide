# Trimble ID Configuration
# TODO: Get your Client ID from: https://developer.trimble.com/console/applications
# 1. Create a new application in Trimble Developer Console
# 2. Configure OAuth grant types: Authorization Code Grant and Use Refresh tokens
# 3. Set Callback URL: <VITE_APP_BASE_URL>/callback
# 4. Set Logout URL: <VITE_APP_BASE_URL>/logout-callback
# 5. Copy your Client ID below

VITE_TRIMBLE_CLIENT_ID=631f09a3-27eb-46e4-80f3-97a7b76e456f

# Trimble Identity Configuration Endpoint
VITE_TRIMBLE_CONFIG_ENDPOINT=https://stage.id.trimblecloud.com/.well-known/openid-configuration
# VITE_TRIMBLE_CONFIG_ENDPOINT=https://id.trimble.com/.well-known/openid-configuration

# Backend API Configuration
VITE_API_URL=https://your-production-api.com

# Frontend base URL used to build OAuth callback/logout URLs
# Example: http://localhost:5173
VITE_APP_BASE_URL=https://trimbleworkride.dev.api.trimblecloud.com/
